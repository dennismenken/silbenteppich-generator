{
  "name": "silbenteppich-generator",
  "private": true,
  "version": "1.0.0",
  "description": "Webapp zur Generierung von Silbenteppichen als Lesehilfe für Kinder",
  "type": "module",
  "scripts": {
    "dev": "npm run check-legal && vite dev",
    "build": "npm run check-legal && vite build",
    "start": "node build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "generate-favicon": "node scripts/generate-favicon.js",
    "check-legal": "node scripts/check-legal-files.js"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.53.4",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^25.3.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "svelte": "^5.35.5",
    "svelte-check": "^4.2.2",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "unplugin-fonts": "^1.4.0",
    "vite": "^7.0.4"
  },
  "dependencies": {
    "@realfavicongenerator/generate-favicon": "^0.4.16",
    "@realfavicongenerator/image-adapter-node": "^0.4.16",
    "lucide-svelte": "^0.534.0",
    "marked": "^16.1.1",
    "playwright-chromium": "^1.58.2"
  }
}
